{
    "name": "gsv",
    "productName": "GSV",
    "version": "0.7.0",
    "description": "GSV",
    "main": "src/index.js",
    "scripts": {
        "start": "electron-forge start",
        "package": "electron-forge package",
        "package:win": "electron-forge package --platform=win32 --arch=x64",
        "verify:win-package": "node scripts/verify-windows-package.js",
        "make": "electron-forge make",
        "make:win": "electron-forge make --platform=win32 --arch=x64 && npm run verify:win-package",
        "publish": "electron-forge publish",
        "lint": "echo \"No linting configured\""
    },
    "keywords": [
        "GSV",
        "GSV ai",
        "GSV ai assistant",
        "GSV ai assistant for interviews"
    ],
    "author": {
        "name": "gurugsv",
        "email": "gurugsv@users.noreply.github.com"
    },
    "license": "GPL-3.0",
    "dependencies": {
        "@google/genai": "^1.2.0",
        "@huggingface/transformers": "^3.8.1",
        "electron-updater": "^6.6.2",
        "electron-squirrel-startup": "^1.0.1",
        "mammoth": "^1.11.0",
        "microsoft-cognitiveservices-speech-sdk": "^1.48.0",
        "ollama": "^0.6.3",
        "pdf-parse": "^1.1.1",
        "tslib": "^2.8.1",
        "ws": "^8.19.0"
    },
    "devDependencies": {
        "@electron-forge/cli": "^7.8.1",
        "@electron-forge/maker-deb": "^7.8.1",
        "@electron-forge/maker-dmg": "^7.8.1",
        "@electron-forge/maker-rpm": "^7.8.1",
        "@electron-forge/maker-squirrel": "^7.8.1",
        "@electron-forge/maker-zip": "^7.8.1",
        "@electron-forge/plugin-auto-unpack-natives": "^7.8.1",
        "@electron-forge/plugin-fuses": "^7.8.1",
        "@electron/fuses": "^1.8.0",
        "@reforged/maker-appimage": "^5.0.0",
        "electron": "^30.0.5"
    }
}
